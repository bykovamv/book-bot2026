# Токен бота (получите у @BotFather в Telegram)
BOT_TOKEN=your_bot_token_here

# Прокси для обхода блокировок (опционально)
# Оставьте пустым, если прокси не нужен
# Примеры:
# HTTP прокси: PROXY_URL=http://proxy.example.com:8080
# SOCKS5 прокси: PROXY_URL=socks5://user:pass@proxy.com:1080
PROXY_URL=
